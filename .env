# 環境：EXT=外網 / INT=內網
ENV=EXT

# 模型選擇改為 AUTO（不再固定單一 MODEL_TYPE）
MODEL_TYPE=OLLAMA

# 模型優先順序
# 當 ENV=EXT（外網）:
MODEL_PRIORITY=GOOGLE,OPENAI,OLLAMA
# 當 ENV=INT（內網，僅 OLLAMA）請改為:
# MODEL_PRIORITY=OLLAMA

DOC_QUERY_ALLOWED_IPS=192.168.0.137
DOC_QUERY_TRUST_X_FORWARDED_FOR=1

# 反向代理前綴
PROXY_PREFIX=
FORCE_SCRIPT_NAME=/djangoai
MOCK_DB_JSON=H:\AI\AI_TOOLS\SQLTEST_output.json
NO_PROXY=127.0.0.1,localhost,::1,.mpc.mil.tw,192.168.0.137
PROXY_PREFIX_WRITE_SCRIPT_NAME=1
TRUST_X_FORWARDED_PREFIX=0
USE_X_FORWARDED_HOST=1
SECURE_PROXY_SSL_VALUE=https 

OLLAMA_BASE_URL=http://192.168.0.137:11434
OLLAMA_MODEL=llama3.1:8b
OLLAMA_MODE=LLM
OLLAMA_EMBED_MODEL=nomic-embed-text

# OpenAI
OPENAI_MODEL=gpt-4o-mini
# OPENAI_API_KEY 建議從系統環境變數讀取

DJANGO_DEBUG=1

# Google Gemini
GOOGLE_MODEL=gemini-flash-latest
# GOOGLE_API_KEY 請僅從系統環境變數讀取（不要寫在 .env）

MODEL_TEMPERATURE=0.2
MODEL_TIMEOUT=300

# RAG / Chroma (精準定位資料夾)
RAG_CHROMA_DIR=H:\AI\AI_TOOLS\chroma\rag
CHROMA_PERSIST_DIR=H:\AI\AI_TOOLS\chroma\rag
CHROMA_DIR=H:\AI\AI_TOOLS\chroma\rag
RAG_CHROMA_COLLECTION=cm_qna
RAG_TOP_K=10

# 權限
PORTAL_ACL_ENABLED=TRUE
PORTAL_ACL_BACKEND=AUTO
ORA_ACL_TABLE=VIEW_ZZ_USER_GROUP_ACL
ORA_ACL_USER_COL=USER_ID
ORA_ACL_GROUP_COL=GROUP_NAME

# 其他
# 測試 git hook 註解
DEBUG=1
ORACLE_ENABLED=1
ORACLE_EMP_ENABLED=1
ORACLE_ACL_ENABLED=1
FORCE_MOCK_DB=1
CSRF_TRUSTED_ORIGINS=https://mpcai.mpc.mil.tw,http://mpcai.mpc.mil.tw


MEETING_INT_TODO_URL=https://www.mpc.mil.tw/notificationsingleton/WebService/CaseManager/UnHandle_Item_AssignJson.ashx
