# ============================================================
# Environment switch (change only ONE line)
# ============================================================
# Supported values:
# - DEV_INT   : 開發環境（內網）
# - DEV_EXT   : 開發環境（外網）
# - PROD_INT  : 正式環境（內網）
# - PROD_EXT  : 正式環境（外網）
ENV=PROD_EXT
# ENV=PROD_INT
# ENV=DEV_INT
# ENV=DEV_EXT

# Mode notes:
# DEV_INT  = debug預設開啟、走內網策略（LLM優先 OLLAMA、資料庫連實體DB）
# DEV_EXT  = debug預設開啟、走外網策略（LLM優先 GOOGLE/OPENAI、資料庫走mock）
# PROD_INT = debug預設關閉、正式安全設定、內網策略（OLLAMA、實體DB）
# PROD_EXT = debug預設關閉、正式安全設定、外網策略（GOOGLE/OPENAI、mock）
# 註：DEV_IN 仍可用，等同 DEV_INT（相容別名）

# Optional manual overrides (normally no need when switching ENV)
# DJANGO_DEBUG=1
# PROXY_PREFIX=/djangoai
# FORCE_SCRIPT_NAME=/djangoai
# SESSION_COOKIE_SECURE=1
# CSRF_COOKIE_SECURE=1
# FORCE_MOCK_DB=1

# ============================================================
# Model routing
# ============================================================
MODEL_TYPE=AUTO
MODEL_PRIORITY=GOOGLE,OPENAI,OLLAMA
MODEL_TEMPERATURE=0.2
MODEL_TIMEOUT=300

# ============================================================
# Hosts / proxy basics
# ============================================================
ALLOWED_HOSTS=mpcai.mpc.mil.tw,10.29.136.17,127.0.0.1,localhost
PROXY_PREFIX_WRITE_SCRIPT_NAME=1
TRUST_X_FORWARDED_PREFIX=0
USE_X_FORWARDED_HOST=1
SECURE_PROXY_SSL_VALUE=https
NO_PROXY=127.0.0.1,localhost,::1,.mpc.mil.tw,192.168.0.137

# ============================================================
# CSRF (default is auto by ENV in settings.py)
# PROD default: https://mpcai.mpc.mil.tw
# DEV default : https://mpcai.mpc.mil.tw,http://mpcai.mpc.mil.tw
# ============================================================
# CSRF_TRUSTED_ORIGINS=https://mpcai.mpc.mil.tw

# ============================================================
# DB / profile
# ============================================================
MOCK_DB_JSON=H:\AI\AI_TOOLS\SQLTEST_output.json
ORACLE_ENABLED=1
ORACLE_EMP_ENABLED=1
ORACLE_ACL_ENABLED=1

# ============================================================
# ACL
# ============================================================
PORTAL_ACL_ENABLED=TRUE
PORTAL_ACL_BACKEND=AUTO
ORA_ACL_TABLE=VIEW_ZZ_USER_GROUP_ACL
ORA_ACL_USER_COL=USER_ID
ORA_ACL_GROUP_COL=GROUP_NAME

# ============================================================
# Sybase query policy
# ============================================================
DOC_QUERY_ALLOWED_IPS=192.168.0.137
DOC_QUERY_TRUST_X_FORWARDED_FOR=1

# ============================================================
# Ollama
# ============================================================
OLLAMA_BASE_URL=http://192.168.0.137:11434
OLLAMA_MODEL=gemma3:4b
OLLAMA_MODE=LLM
OLLAMA_EMBED_MODEL=nomic-embed-text
OLLAMA_FALLBACK_MODELS=gemma3:4b,qwen3:8b

# ============================================================
# OpenAI
# ============================================================
OPENAI_MODEL=gpt-4o-mini
# OPENAI_API_KEY from system env

# ============================================================
# Google Gemini
# ============================================================
GOOGLE_MODEL=gemini-flash-latest
# GOOGLE_API_KEY from system env

# ============================================================
# RAG / Chroma
# ============================================================
RAG_CHROMA_DIR=H:\AI\AI_TOOLS\chroma\rag
CHROMA_PERSIST_DIR=H:\AI\AI_TOOLS\chroma\rag
CHROMA_DIR=H:\AI\AI_TOOLS\chroma\rag
RAG_CHROMA_COLLECTION=cm_qna
RAG_TOP_K=10

# ============================================================
# Meeting API
# ============================================================
MEETING_INT_TODO_URL=https://www.mpc.mil.tw/notificationsingleton/WebService/CaseManager/UnHandle_Item_AssignJson.ashx
