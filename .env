# ============================================================
# 環境切換（只改這一行）
# 支援：PROD_INT / DEV_INT / PROD_EXT / DEV_EXT
# ============================================================
ENV=DEV_EXT
# ENV=PROD_EXT
# ENV=PROD_INT
# ENV=DEV_INT
# ENV=DEV_EXT

# ============================================================
# 統一參數（所有環境共用）
# ============================================================
MODEL_TYPE=AUTO
MODEL_TEMPERATURE=0.2
MODEL_TIMEOUT=300

ALLOWED_HOSTS=mpcai.mpc.mil.tw,10.29.136.17,127.0.0.1,localhost
PROXY_PREFIX__DEV_INT=
FORCE_SCRIPT_NAME__DEV_INT=
PROXY_PREFIX__DEV_EXT=
FORCE_SCRIPT_NAME__DEV_EXT=
PROXY_PREFIX__PROD_INT=/djangoai
FORCE_SCRIPT_NAME__PROD_INT=/djangoai
PROXY_PREFIX__PROD_EXT=/djangoai
FORCE_SCRIPT_NAME__PROD_EXT=/djangoai
PROXY_PREFIX_WRITE_SCRIPT_NAME=1
TRUST_X_FORWARDED_PREFIX=0
USE_X_FORWARDED_HOST=1
SECURE_PROXY_SSL_VALUE=https

MOCK_DB_JSON=H:\AI\AI_TOOLS\SQLTEST_output.json
ORACLE_ENABLED=1
ORACLE_EMP_ENABLED=1
ORACLE_ACL_ENABLED=1

PORTAL_ACL_ENABLED=TRUE
PORTAL_ACL_BACKEND=AUTO
ORA_ACL_TABLE=VIEW_ZZ_USER_GROUP_ACL
ORA_ACL_USER_COL=USER_ID
ORA_ACL_GROUP_COL=GROUP_NAME

DOC_QUERY_ALLOWED_IPS=192.168.0.137
DOC_QUERY_TRUST_X_FORWARDED_FOR=1

OLLAMA_BASE_URL=http://192.168.0.137:11434
OLLAMA_MODEL=gemma3:4b
OLLAMA_MODE=LLM
OLLAMA_EMBED_MODEL=nomic-embed-text
OLLAMA_FALLBACK_MODELS=gemma3:4b,qwen3:8b

OPENAI_MODEL=gpt-4o-mini
# OPENAI_API_KEY 由系統環境變數提供

GOOGLE_MODEL=gemini-flash-latest
# GOOGLE_API_KEY 由系統環境變數提供

RAG_CHROMA_DIR=H:\AI\AI_TOOLS\chroma\rag
CHROMA_PERSIST_DIR=H:\AI\AI_TOOLS\chroma\rag
CHROMA_DIR=H:\AI\AI_TOOLS\chroma\rag
RAG_CHROMA_COLLECTION=cm_qna
RAG_TOP_K=10

MEETING_INT_TODO_URL=https://www.mpc.mil.tw/notificationsingleton/WebService/CaseManager/UnHandle_Item_AssignJson.ashx

# ============================================================
# 環境覆寫規則（統一格式）
# 寫法：KEY__ENV_NAME=值
# 例：MODEL_PRIORITY__PROD_INT=OLLAMA
# ============================================================

# 1) Debug 行為
DJANGO_DEBUG__DEV_INT=1
DJANGO_DEBUG__DEV_EXT=1
DJANGO_DEBUG__PROD_INT=0
DJANGO_DEBUG__PROD_EXT=0

# 2) LLM 優先序（只改 ENV 即套用）
MODEL_PRIORITY__DEV_INT=OLLAMA
MODEL_PRIORITY__PROD_INT=OLLAMA
MODEL_PRIORITY__DEV_EXT=GOOGLE,OPENAI,OLLAMA
MODEL_PRIORITY__PROD_EXT=GOOGLE,OPENAI,OLLAMA

# 3) NO_PROXY（僅內網環境需要）
NO_PROXY__DEV_INT=127.0.0.1,localhost,::1,.mpc.mil.tw,192.168.0.137
NO_PROXY__PROD_INT=127.0.0.1,localhost,::1,.mpc.mil.tw,192.168.0.137

# 4) Cookie 安全（正式環境強制，開發環境可關）
SESSION_COOKIE_SECURE__DEV_INT=0
CSRF_COOKIE_SECURE__DEV_INT=0
SESSION_COOKIE_SECURE__DEV_EXT=0
CSRF_COOKIE_SECURE__DEV_EXT=0
SESSION_COOKIE_SECURE__PROD_INT=1
CSRF_COOKIE_SECURE__PROD_INT=1
SESSION_COOKIE_SECURE__PROD_EXT=1
CSRF_COOKIE_SECURE__PROD_EXT=1
