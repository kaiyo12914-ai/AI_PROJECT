# ==========================================
# LLM Factory Config
# ==========================================
# Provider: GOOGLE | OPENAI | OLLAMA | LM_STUDIO
MODEL_TYPE=OPENAI

# Ollama
OLLAMA_BASE_URL=http://192.168.0.137:11434
OLLAMA_MODEL=gemma3:4b
OLLAMA_EMBEDDING_MODEL=nomic-embed-text
OLLAMA_FALLBACK_MODELS=gemma3:4b,qwen3:8b

# LM Studio
LM_STUDIO_BASE_URL=http://mpcai.mpc.mil.tw:1234/v1
LM_STUDIO_MODEL=gemma-4

# Google Gemini
GOOGLE_MODEL=gemini-3-flash-preview
# GEMINI_API_KEY=
# GOOGLE_API_KEY=

# OpenAI
OPENAI_MODEL=gpt-5.3-codex
# OPENAI_MODEL=gpt-4.1
# OPENAI_API_KEY=

# Shared model params
MODEL_TEMPERATURE=0.2
MODEL_TIMEOUT=300

# ==========================================
# Infrastructure
# ==========================================
ENV=EXT
DATABASE_URL=postgres://projectnotes_user:mpcdbadm@192.168.0.137:5432/projectnotes
REDIS_URL=redis://localhost:6379/0
AUTO_CREATE_TABLES=true
DJANGO_DEBUG=1
DEBUG=1
NO_PROXY=127.0.0.1,localhost,::1,.mpc.mil.tw,192.168.0.137

# Reverse proxy
PROXY_PREFIX=
FORCE_SCRIPT_NAME=
PROXY_PREFIX_WRITE_SCRIPT_NAME=0
TRUST_X_FORWARDED_PREFIX=0
USE_X_FORWARDED_HOST=1
SECURE_PROXY_SSL_VALUE=https
CSRF_TRUSTED_ORIGINS=https://mpcai.mpc.mil.tw,http://mpcai.mpc.mil.tw

# ==========================================
# RAG (PostgreSQL)
# ==========================================
RAG_BACKEND=postgres
RAG_PG_TABLE=public.meeting_records
RAG_TOP_K=10

# ==========================================
# Security / ACL
# ==========================================
PORTAL_ACL_ENABLED=TRUE
PORTAL_ACL_BACKEND=ORACLE
ACL_BACKEND_EFFECTIVE=ORACLE
ORA_ACL_TABLE=VIEW_ZZ_USER_GROUP_ACL
ORA_ACL_USER_COL=USER_ID
ORA_ACL_GROUP_COL=GROUP_NAME

# ==========================================
# Others
# ==========================================
ORACLE_ENABLED=1
ORACLE_EMP_ENABLED=1
ORACLE_ACL_ENABLED=1
FORCE_MOCK_DB=1
MOCK_DB_JSON=H:\AI\AI_TOOLS\SQLTEST_output.json
DOC_QUERY_ALLOWED_IPS=192.168.0.137
DOC_QUERY_TRUST_X_FORWARDED_FOR=1
MEETING_INT_TODO_URL=https://www.mpc.mil.tw/notificationsingleton/WebService/CaseManager/UnHandle_Item_AssignJson.ashx

FFMPEG_BIN=D:\ffmpeg\bin\ffmpeg.exe
YTDLP_BIN=yt-dlp
